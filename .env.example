# PixelBin — get from https://console.pixelbin.io/organization/settings/api-tokens
PIXELBIN_API_TOKEN=your-api-token-here
PIXELBIN_ACCESS_KEY=your-access-key-here
PIXELBIN_CLOUD_NAME=your-cloud-name   # Find in PixelBin console > Settings

# Slack (create app at https://api.slack.com/apps)
SLACK_BOT_TOKEN=xoxb-your-bot-token
SLACK_SIGNING_SECRET=your-signing-secret
SLACK_APP_TOKEN=xapp-your-app-token   # Only needed for socket mode

# Your app's public URL (set by Vercel automatically, or ngrok for local dev)
NEXT_PUBLIC_APP_URL=https://your-app.vercel.app

# Instagram (Meta Graph API)
# Get from: https://developers.facebook.com/apps
INSTAGRAM_ACCESS_TOKEN=
INSTAGRAM_BUSINESS_ACCOUNT_ID=

# LinkedIn
# Get from: https://www.linkedin.com/developers/apps
LINKEDIN_ACCESS_TOKEN=
LINKEDIN_PERSON_URN=          # urn:li:person:XXXXX  (personal)
LINKEDIN_ORG_URN=             # urn:li:organization:XXXXX  (company page, optional)

# Twitter / X
# Get from: https://developer.twitter.com/en/portal
TWITTER_API_KEY=
TWITTER_API_SECRET=
TWITTER_ACCESS_TOKEN=
TWITTER_ACCESS_TOKEN_SECRET=

# YouTube
# Get from: https://console.cloud.google.com
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
YOUTUBE_REFRESH_TOKEN=
